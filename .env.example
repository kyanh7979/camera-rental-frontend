# ─── API ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api

# ─── Camera endpoint (if different from API base) ───────────────────────────
VITE_CAMERA_ENDPOINT=/cameras

# ─── Telegram Bot (Frontend reads these for notification service) ────────────
# Set to 'true' to enable Telegram notifications
VITE_TELEGRAM_ENABLED=false

# Telegram Bot Token — get from @BotFather
VITE_TELEGRAM_BOT_TOKEN=

# Telegram Chat ID — get from @userinfobot or your channel ID
VITE_TELEGRAM_CHAT_ID=

# Backend endpoint that handles Telegram API calls (backend must implement)
VITE_TELEGRAM_NOTIFY_ENDPOINT=/api/telegram/notify
